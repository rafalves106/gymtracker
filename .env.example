# ==========================================================
# GymTracker - Variáveis de Ambiente (EXEMPLO)
# Copie este arquivo para .env e preencha com valores reais:
#   cp .env.example .env
# NUNCA preencha segredos reais aqui neste .example!
# ==========================================================

# ----- PostgreSQL 18 -----
POSTGRES_USER=gym
POSTGRES_PASSWORD=defina_uma_senha_forte
POSTGRES_DB=gymtracker

# ----- JWT (mínimo 32 caracteres na chave) -----
JWT_KEY=gere_uma_chave_aleatoria_com_no_minimo_32_caracteres
JWT_ISSUER=gym-tracker
JWT_AUDIENCE=gym-tracker-app

# ----- Usuário master (seed inicial) -----
MASTER_USERNAME=falvesadm
MASTER_EMAIL=seu-email@exemplo.com
MASTER_PASSWORD=defina_uma_senha_forte_e_nova

# ----- CORS / Frontend -----
CORS_ORIGIN=https://app.seudominio.com
VITE_API_URL=/api

# ----- Cloudflare Tunnel -----
# Token gerado no painel Zero Trust > Networks > Tunnels
CLOUDFLARE_TUNNEL_TOKEN=cole_o_token_do_tunnel_aqui